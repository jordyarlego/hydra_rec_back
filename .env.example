# ============ HydraRec V3 — Plataforma Cívica ============

# === IA ===
GEMINI_API_KEY=sua_chave_gemini_aqui        # Vision (foto de reports)
NVIDIA_API_KEY=sua_chave_nvidia_aqui        # NIM: Nemotron 49B / Llama 70B (textos PT-BR)

# === Supabase (Settings > API) ===
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=sb_publishable_xxxx
SUPABASE_SERVICE_KEY=sb_secret_xxxx
SUPABASE_JWT_SECRET=                         # opcional; sem ele o backend valida admin via Supabase Auth
SUPABASE_STORAGE_BUCKET=report-photos

# === Segurança ===
IP_HASH_SALT=troque-por-string-aleatoria-longa
RATE_LIMIT_REPORTS_SECONDS=300
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# === Push Web ===
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:seu-email@dominio.com
PUSH_TEST_TOKEN=troque-por-token-longo-para-teste

# === Observabilidade (Fase 5) ===
SENTRY_DSN=

# === DEPRECATED (V2) — não usar ===
# OPENWEATHER_KEY ❌  (substituído pelos JSONs oficiais APAC)
